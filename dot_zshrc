aws-profile() {
 local profile
 profile=$(aws configure list-profiles | fzf --height 40% --border --prompt "Select AWS Profile> ") || return

 export AWS_PROFILE="$profile"
 echo "Ã¢â€ â€™ Switched to profile: $AWS_PROFILE"

 # Check if it's an SSO profile
 if aws configure get sso_start_url --profile "$profile" >/dev/null 2>&1; then
  echo "Ã¢â€ â€™ Detected SSO profile: $profile"

  # Call AWS SSO login using `command` (no function/shell interference)
  command aws sso login --profile "$profile"
 fi

 # Now validate
 if ! aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
  aws sso login --profile $profile
 fi

 echo "Ã¢â€ â€™ Identity for $profile:"
 aws sts get-caller-identity --profile "$profile" --output yaml

 aws codeartifact login --tool pip \
   --repository tavily-internal-packages \
   --domain tavily \
   --domain-owner 598432549459 \
   --region us-east-1 > /dev/null 2>&1 || echo "Login failed: $?"
}

setopt PROMPT_SUBST

# Enable colors
