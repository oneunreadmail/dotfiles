venv() {
  if [ -d "venv" ]; then
    echo ":white_check_mark: Activating existing venv..."
  else
    echo ":gear: Creating new venv..."
    python3 -m venv venv || { echo ":x: Failed to create venv"; return 1; }
  fi

  source venv/bin/activate

  if [ -f "requirements.txt" ]; then
    echo ":package: Installing requirements..."
    pip install --upgrade pip
    pip install -r requirements.txt
  fi
}

